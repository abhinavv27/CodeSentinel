# CodeSentinel Environment Configuration

# Application
APP_NAME=CodeSentinel
DEBUG=True

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/codesentinel

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub App Credentials
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=

# Qdrant (Vector DB)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=codebase
QDRANT_FEEDBACK_COLLECTION=feedback_memory

# Model (vLLM / Ollama)
MODEL_ENDPOINT=http://localhost:11434/v1
MODEL_NAME=codellama:7b
MODEL_MAX_TOKENS=2048

# Langfuse (Observability)
# Get keys from https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Notifications
SLACK_WEBHOOK_URL=
